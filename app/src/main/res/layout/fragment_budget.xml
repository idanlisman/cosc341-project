<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Monthly Budget Remaining card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_card"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY BUDGET REMAINING"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/budget_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 4,673"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/spent_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spent: $4,479"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/total_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: $9,000"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Categories header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CATEGORIES"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View All"
                android:textColor="@color/accent"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Category list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/category_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <!-- Bottom buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_category"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NEW CATEGORY"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_camera"
                app:iconSize="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_budgets"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EDIT BUDGETS"
                android:textSize="11sp"
                android:layout_marginStart="8dp"
                app:icon="@drawable/ic_custom"
                app:iconSize="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
